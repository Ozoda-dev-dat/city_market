modules = ["nodejs-20", "web", "bash", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EXPO_NO_TELEMETRY=1 PORT=8080 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_ROUTER_IMPORT_MODE=lazy node_modules/.bin/expo start --port 8080 --host lan --clear"
waitForPort = 8080

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[userenv]

[userenv.shared]
JWT_SECRET = "local-dev-jwt-secret-key-change-in-production"
JWT_REFRESH_SECRET = "local-dev-refresh-secret-key-change-in-production"
NODE_ENV = "development"
API_KEYS = "local-dev-api-key"
BACKUP_ENCRYPTION_KEY = "34958ddc29ac71c957e5c718bce2293a63b6f59ec225150803ba3a357728a72c0344a5b7ff32259459d72e0b0605b45012a88ee6aedb9f90f4e792b4d8ca4e4b"
DATA_RETENTION_DAYS = "90"
ENCRYPTION_KEY = "3aa3d9cd590251257a7c01601035dc34f19b95bc3268b4a833d82392810f35274e17253399b7d519c535f644e5bf1f4adcf829f4ae3c89af154252c574935002"
PORT = "5000"
PRODUCTION_DOMAIN = "localhost"
YOUR_DOMAIN = "localhost"
