{
  "name": "freshmart-tests",
  "version": "1.0.0",
  "description": "Test suite for FreshMart app",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:e2e": "detox test",
    "test:e2e:build": "detox build --configuration ios.sim.debug",
    "test:integration": "jest --testPathPattern=integration",
    "test:unit": "jest --testPathPattern=unit",
    "test:components": "jest --testPathPattern=components",
    "test:hooks": "jest --testPathPattern=hooks",
    "test:utils": "jest --testPathPattern=utils",
    "test:report": "jest --coverage --coverageReporters=text-lcov | coveralls",
    "test:clean": "jest --clearCache",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.5",
    "@types/react-test-renderer": "^18.0.7",
    "detox": "^20.13.5",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "react-test-renderer": "^18.2.0",
    "ts-jest": "^29.1.1",
    "coveralls": "^3.1.1",
    "@testing-library/jest-dom": "^6.1.4",
    "jest-mock-extended": "^3.0.5",
    "msw": "^2.0.8"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.ts"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.{js,jsx,ts,tsx}",
      "<rootDir>/src/**/*.test.{js,jsx,ts,tsx}",
      "<rootDir>/app/**/*.test.{js,jsx,ts,tsx}",
      "<rootDir>/components/**/*.test.{js,jsx,ts,tsx}",
      "<rootDir>/context/**/*.test.{js,jsx,ts,tsx}",
      "<rootDir>/hooks/**/*.test.{js,jsx,ts,tsx}",
      "<rootDir>/lib/**/*.test.{js,jsx,ts,tsx}",
      "<rootDir>/utils/**/*.test.{js,jsx,ts,tsx}"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "app/**/*.{js,jsx,ts,tsx}",
      "components/**/*.{js,jsx,ts,tsx}",
      "context/**/*.{js,jsx,ts,tsx}",
      "hooks/**/*.{js,jsx,ts,tsx}",
      "lib/**/*.{js,jsx,ts,tsx}",
      "utils/**/*.{js,jsx,ts,tsx}",
      "!**/*.d.ts",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/tests/**",
      "!**/scripts/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html",
      "json",
      "clover"
    ],
    "coverageThresholds": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      },
      "./src/components/": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      },
      "./src/hooks/": {
        "branches": 85,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    },
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react|@react-navigation|@react-native-async-storage|@reduxjs/toolkit|react-query)/)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "testEnvironment": "jsdom",
    "setupFiles": [
      "<rootDir>/tests/polyfills.js"
    ],
    "moduleNameMapping": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testTimeout": 10000
  },
  "detox": {
    "testRunner": "jest",
    "runnerConfig": "tests/e2e/config.json",
    "configurations": {
      "ios.sim.debug": {
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/FreshMart.app",
        "build": "xcodebuild -workspace ios/FreshMart.xcworkspace -scheme FreshMart -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build",
        "type": "ios.simulator",
        "device": {
          "type": "iPhone 15"
        }
      },
      "android.emu.debug": {
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "build": "cd android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug",
        "type": "android.emulator",
        "device": {
          "avdName": "Pixel_4_API_30"
        }
      }
    }
  }
}
